# =============================================================================
# CuteGoals 2.0 — 环境变量模板
# 复制为 .env 并填写实际值后再启动 Docker Compose
#   cp deploy/.env.template .env
# =============================================================================

# ── 实例标识 ──────────────────────────────────────────────────────────────
# 初始化一次性令牌（首次部署必填；初始化成功后应移除或留空）
INIT_TOKEN=

# ── MySQL ──────────────────────────────────────────────────────────────────
MYSQL_ROOT_PASSWORD=          # 必填：MySQL root 密码
MYSQL_DATABASE=cutegoals      # 数据库名（默认 cutegoals）
MYSQL_USER=cutegoals          # 应用数据库用户
MYSQL_PASSWORD=               # 必填：应用数据库用户密码

# ── Redis ──────────────────────────────────────────────────────────────────
REDIS_PASSWORD=               # 必填：Redis 密码

# ── 应用配置 ───────────────────────────────────────────────────────────────
SERVER_PORT=8080              # 后端端口（容器内）
JWT_SECRET=                   # 必填：JWT 签名密钥（至少 32 字符随机字符串）
APP_DOMAIN=localhost          # 部署域名（影响 Cookie 域与 CSP）

# ── 可选：短信服务 ─────────────────────────────────────────────────────────
# 未配置时短信验证码登录功能关闭，不影响密码登录
SMS_PROVIDER=
SMS_ACCESS_KEY=
SMS_ACCESS_SECRET=

# ── 日志 ───────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO                # 日志级别：TRACE | DEBUG | INFO | WARN | ERROR
LOG_APPENDER=CONSOLE          # 日志输出：CONSOLE | FILE | BOTH

# ── 备份 ───────────────────────────────────────────────────────────────────
BACKUP_DIR=/data/backup       # 备份文件存放目录（容器内路径）
BACKUP_RETENTION_DAYS=7       # 每日备份保留天数
BACKUP_RETENTION_WEEKS=4      # 每周备份保留周数
BACKUP_RETENTION_MONTHS=3     # 每月备份保留月数
