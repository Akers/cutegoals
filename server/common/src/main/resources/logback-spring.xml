<?xml version="1.0" encoding="UTF-8"?>
<configuration>
    <!-- Include Spring Boot defaults for common patterns -->
    <include resource="org/springframework/boot/logging/logback/defaults.xml"/>

    <!-- Resolve app properties from Spring Environment -->
    <springProperty name="APP_NAME" source="app.name" defaultValue="CuteGoals"/>
    <springProperty name="APP_TIMEZONE" source="app.timezone" defaultValue="Asia/Shanghai"/>

    <!-- JSON structured console appender -->
    <appender name="JSON_CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
        <encoder class="net.logstash.logback.encoder.LogstashEncoder">
            <includeCallerData>false</includeCallerData>
            <fieldNames>
                <timestamp>timestamp</timestamp>
                <level>level</level>
                <logger>logger_name</logger>
                <thread>thread_name</thread>
                <levelValue>[ignore]</levelValue>
                <version>[ignore]</version>
            </fieldNames>
            <customFields>{"app":"${APP_NAME}","timezone":"${APP_TIMEZONE}"}</customFields>
            <timeZone>${APP_TIMEZONE}</timeZone>
        </encoder>
    </appender>

    <!-- Suppress MyBatis SQL parameter logging at DEBUG level to prevent phone number leakage -->
    <!-- NOTE: org.mybatis / org.apache.ibatis loggers don't cover mapper-class logs;
         MyBatis-Plus uses the mapper class fully qualified name as logger. -->
    <logger name="org.mybatis" level="INFO"/>
    <logger name="org.apache.ibatis" level="INFO"/>
    <!-- Suppress mapper-level DEBUG logs to hide SQL parameters; service/controller retain DEBUG -->
    <logger name="com.cutegoals.auth.mapper" level="INFO"/>
    <logger name="com.cutegoals.family.mapper" level="INFO"/>
    <logger name="com.cutegoals.task.mapper" level="INFO"/>
    <logger name="com.cutegoals.points.mapper" level="INFO"/>
    <logger name="com.cutegoals.prize.mapper" level="INFO"/>
    <logger name="com.cutegoals.exchange.mapper" level="INFO"/>
    <logger name="com.cutegoals.instancemanagement.mapper" level="INFO"/>
    <logger name="com.cutegoals.taskreview.mapper" level="INFO"/>

    <!-- Root logger: INFO and above to JSON console -->
    <!-- Application package levels are configured via application.yml / environment -->
    <root level="INFO">
        <appender-ref ref="JSON_CONSOLE"/>
    </root>
</configuration>
